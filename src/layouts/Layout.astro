---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Universo Musical: tienda de instrumentos y servicios para artistas y productores.'
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Oswald:wght@500;700&display=swap"
      rel="stylesheet"
    />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --color-black: #0b0b0b;
    --color-yellow: #ffd100;
    --color-red: #d90429;
    --color-white: #f5f5f5;
    --color-ink-soft: #d8d8d8;
    --color-panel: #111111;
    --color-panel-alt: #171717;
    --gradient-hero: radial-gradient(circle at 14% 18%, rgba(255, 209, 0, 0.34) 0%, rgba(255, 209, 0, 0) 38%),
      radial-gradient(circle at 85% 14%, rgba(217, 4, 41, 0.32) 0%, rgba(217, 4, 41, 0) 37%),
      linear-gradient(135deg, #0b0b0b 0%, #111111 55%, #0b0b0b 100%);
    --gradient-accent: linear-gradient(120deg, var(--color-yellow) 0%, #ffb703 30%, #ff6d00 55%, var(--color-red) 100%);
    --shadow-card: 0 16px 40px rgba(0, 0, 0, 0.38);
    --radius-card: 20px;
    --container-width: 1160px;
    --transition-fast: 220ms ease;
    --transition-medium: 280ms ease;
  }

  * {
    box-sizing: border-box;
  }

  html {
    font-family: 'Manrope', sans-serif;
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-height: 100vh;
    color: var(--color-white);
    background: var(--gradient-hero);
    line-height: 1.5;
    text-rendering: optimizeLegibility;
  }

  img,
  svg {
    max-width: 100%;
    height: auto;
    display: block;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  h1,
  h2,
  h3,
  .display-font {
    font-family: 'Oswald', sans-serif;
    letter-spacing: 0.02em;
    margin: 0;
    line-height: 1.05;
  }

  p {
    margin: 0;
  }

  .container {
    width: min(var(--container-width), 100% - 2rem);
    margin-inline: auto;
  }

  .section {
    padding-block: clamp(3.25rem, 7vw, 6.5rem);
  }

  .section-head {
    display: grid;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .section-kicker {
    color: var(--color-yellow);
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-weight: 700;
  }

  .section-title {
    font-size: clamp(2rem, 4.4vw, 3.4rem);
    max-width: 15ch;
  }

  .section-copy {
    color: var(--color-ink-soft);
    max-width: 62ch;
  }

  .btn {
    border: 1px solid transparent;
    border-radius: 999px;
    padding: 0.78rem 1.5rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    font-weight: 700;
    font-size: 0.96rem;
    cursor: pointer;
    transition:
      transform var(--transition-fast),
      box-shadow var(--transition-fast),
      border-color var(--transition-fast),
      background-color var(--transition-fast),
      color var(--transition-fast);
  }

  .btn:hover {
    transform: translateY(-2px);
  }

  .btn-primary {
    background: var(--gradient-accent);
    color: var(--color-black);
    box-shadow: 0 14px 30px rgba(217, 4, 41, 0.35);
  }

  .btn-primary:hover {
    box-shadow: 0 16px 36px rgba(255, 209, 0, 0.3);
  }

  .btn-outline {
    border-color: rgba(255, 255, 255, 0.35);
    background: rgba(255, 255, 255, 0.05);
    color: var(--color-white);
  }

  .btn-outline:hover {
    border-color: rgba(255, 209, 0, 0.85);
    background: rgba(255, 209, 0, 0.09);
  }

  :where(a, button, input, textarea):focus-visible {
    outline: 3px solid var(--color-yellow);
    outline-offset: 3px;
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
      scroll-behavior: auto !important;
    }
  }

  @media (min-width: 720px) {
    .section-head {
      margin-bottom: 2.6rem;
    }
  }
</style>
