---
import CatalogCard from './CatalogCard.astro';
import { createCatalogWhatsAppMessage, createWhatsAppLink } from '../lib/whatsapp';
import type { CatalogOverview } from '../lib/catalog';

interface Props {
  eyebrow: string;
  title: string;
  intro: string;
  overview: CatalogOverview;
}

const { eyebrow, title, intro, overview } = Astro.props;

const sectionLabel = overview.group === 'instrumentos' ? 'instrumentos' : 'accesorios';
const whatsAppLink = createWhatsAppLink(createCatalogWhatsAppMessage(sectionLabel));
---

<section class:list={['catalog-shell', `is-${overview.group}`]} data-catalog-root>
  <div class="catalog-hero panel">
    <div class="catalog-hero-copy">
      <p class="eyebrow">{eyebrow}</p>
      <h1 class="display-font">{title}</h1>
      <p>{intro}</p>
    </div>

    <div class="catalog-hero-aside">
      <div class="stat-card">
        <strong>{overview.totalItems}</strong>
        <span>referencias limpias y consolidadas</span>
      </div>
      <div class="stat-card">
        <strong>{overview.availableItems}</strong>
        <span>con disponibilidad visible</span>
      </div>
      <div class="stat-card">
        <strong>{overview.pricedItems}</strong>
        <span>con precio publicado</span>
      </div>
      <a class="button button-secondary" href={whatsAppLink} target="_blank" rel="noreferrer">
        Pedir asesoria por WhatsApp
      </a>
    </div>
  </div>

  <div class="catalog-controls panel">
    <label class="search-field" for={`search-${overview.group}`}>
      <span>Buscar por nombre o familia</span>
      <input
        id={`search-${overview.group}`}
        data-catalog-search
        type="search"
        inputmode="search"
        placeholder={`Buscar en ${sectionLabel}`}
        autocomplete="off"
      />
    </label>

    <div class="filter-strip" role="toolbar" aria-label={`Filtros del catalogo de ${sectionLabel}`}>
      <button class="filter-chip is-active" data-filter-button data-filter-value="all" type="button" aria-pressed="true">
        Todas <span>{overview.totalItems}</span>
      </button>
      {
        overview.familySummaries.map((family) => (
          <button
            class="filter-chip"
            data-filter-button
            data-filter-value={family.key}
            type="button"
            aria-pressed="false"
          >
            {family.family} <span>{family.total}</span>
          </button>
        ))
      }
    </div>

    <div class="results-strip">
      <p data-results-count>
        {overview.totalItems} {overview.totalItems === 1 ? 'resultado' : 'resultados'}
      </p>
      <a href={whatsAppLink} target="_blank" rel="noreferrer">
        Consultar todo por WhatsApp
      </a>
    </div>
  </div>

  <div class="catalog-grid">
    {overview.items.map((item) => <CatalogCard item={item} />)}
  </div>

  <div class="empty-state panel" data-empty-state hidden>
    <p class="eyebrow">Sin coincidencias</p>
    <h2 class="display-font">No encontramos productos con ese filtro.</h2>
    <p>Prueba otra palabra, vuelve a “Todas” o escribenos por WhatsApp para ayudarte a encontrarlo.</p>
  </div>
</section>

<script is:inline>
  const catalogRoots = document.querySelectorAll('[data-catalog-root]');

  for (const root of catalogRoots) {
    const searchInput = root.querySelector('[data-catalog-search]');
    const buttons = Array.from(root.querySelectorAll('[data-filter-button]'));
    const cards = Array.from(root.querySelectorAll('[data-catalog-card]'));
    const resultsLabel = root.querySelector('[data-results-count]');
    const emptyState = root.querySelector('[data-empty-state]');
    let activeFilter = 'all';

    const normalize = (value) =>
      value
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .toLowerCase()
        .trim();

    const sync = () => {
      const term = normalize(searchInput?.value ?? '');
      let visible = 0;

      for (const card of cards) {
        const family = card.getAttribute('data-family') ?? '';
        const searchable = card.getAttribute('data-search') ?? '';
        const matchesFilter = activeFilter === 'all' || family === activeFilter;
        const matchesTerm = !term || searchable.includes(term);
        const shouldShow = matchesFilter && matchesTerm;

        card.hidden = !shouldShow;

        if (shouldShow) {
          visible += 1;
        }
      }

      if (resultsLabel) {
        resultsLabel.textContent = `${visible} ${visible === 1 ? 'resultado' : 'resultados'}`;
      }

      if (emptyState) {
        emptyState.hidden = visible !== 0;
      }
    };

    for (const button of buttons) {
      button.addEventListener('click', () => {
        activeFilter = button.getAttribute('data-filter-value') ?? 'all';

        for (const otherButton of buttons) {
          const pressed = otherButton === button;
          otherButton.classList.toggle('is-active', pressed);
          otherButton.setAttribute('aria-pressed', String(pressed));
        }

        sync();
      });
    }

    searchInput?.addEventListener('input', sync);
    sync();
  }
</script>

<style>
  .catalog-shell {
    display: grid;
    gap: 1.25rem;
  }

  .catalog-hero {
    display: grid;
    gap: 1.5rem;
  }

  .catalog-hero-copy {
    display: grid;
    gap: 0.9rem;
  }

  .catalog-hero-copy h1 {
    font-size: clamp(3rem, 8vw, 5.8rem);
    line-height: 0.92;
  }

  .catalog-hero-copy p:last-child {
    max-width: 60ch;
    color: var(--color-muted);
  }

  .catalog-hero-aside {
    display: grid;
    gap: 0.85rem;
  }

  .stat-card {
    display: grid;
    gap: 0.25rem;
    padding: 0.95rem 1rem;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .stat-card strong {
    font-size: 1.45rem;
    color: var(--color-foreground);
  }

  .stat-card span {
    color: var(--color-muted);
    font-size: 0.9rem;
  }

  .catalog-controls {
    display: grid;
    gap: 1rem;
  }

  .search-field {
    display: grid;
    gap: 0.55rem;
  }

  .search-field span {
    color: var(--color-muted);
    font-size: 0.85rem;
    font-weight: 600;
  }

  .search-field input {
    min-height: 3.35rem;
    padding: 0 1rem;
    border-radius: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--color-foreground);
    background: rgba(11, 15, 22, 0.72);
    font: inherit;
  }

  .filter-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .filter-chip {
    min-height: 2.7rem;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0 0.95rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--color-muted);
    background: rgba(255, 255, 255, 0.04);
    font: inherit;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition:
      transform var(--transition-fast),
      color var(--transition-fast),
      border-color var(--transition-fast),
      background-color var(--transition-fast);
  }

  .filter-chip:hover,
  .filter-chip.is-active {
    color: var(--color-base);
    border-color: rgba(240, 173, 78, 0.38);
    background: linear-gradient(135deg, var(--color-accent), var(--color-secondary));
  }

  .filter-chip span {
    opacity: 0.75;
  }

  .results-strip {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.75rem;
    align-items: center;
  }

  .results-strip p {
    color: var(--color-muted);
    font-weight: 600;
  }

  .results-strip a {
    color: var(--color-accent-soft);
    font-weight: 600;
  }

  .catalog-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(17rem, 1fr));
  }

  .empty-state {
    display: grid;
    gap: 0.75rem;
    text-align: center;
    justify-items: center;
  }

  .empty-state h2 {
    font-size: clamp(2.4rem, 8vw, 4rem);
    line-height: 0.94;
  }

  .empty-state p:last-child {
    max-width: 52ch;
    color: var(--color-muted);
  }

  @media (min-width: 960px) {
    .catalog-hero {
      grid-template-columns: minmax(0, 1.3fr) minmax(18rem, 24rem);
      align-items: start;
    }
  }
</style>
