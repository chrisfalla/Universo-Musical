---
import { WHATSAPP_DISPLAY, createWhatsAppLink } from '../lib/whatsapp';

const whatsAppLink = createWhatsAppLink(
  'Hola, quiero recibir asesoria sobre el catalogo de Universo Musical.'
);
---

<footer class="site-footer">
  <div class="container footer-shell">
    <div class="footer-copy">
      <p class="eyebrow">Contacto directo</p>
      <h2 class="display-font">Una web clara arriba. Una conversacion directa abajo.</h2>
      <p>
        Universo Musical deja el cierre comercial en el canal mas agil para el negocio: atencion directa
        por WhatsApp al numero {WHATSAPP_DISPLAY}.
      </p>
    </div>

    <div class="footer-actions">
      <a class="button button-primary" href={whatsAppLink} target="_blank" rel="noreferrer">
        Hablar por WhatsApp
      </a>
      <a class="button button-secondary" href="/instrumentos">Ver instrumentos</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    padding: 0 0 4rem;
  }

  .footer-shell {
    display: grid;
    gap: 1.4rem;
    padding: clamp(1.35rem, 3vw, 2.2rem);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 1.7rem;
    background:
      linear-gradient(140deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.02)),
      radial-gradient(circle at left top, rgba(255, 209, 0, 0.14), transparent 34%),
      radial-gradient(circle at right bottom, rgba(217, 4, 41, 0.18), transparent 40%),
      #101010;
    box-shadow: var(--shadow-card);
  }

  .footer-copy {
    display: grid;
    gap: 0.8rem;
  }

  .footer-copy h2 {
    font-size: clamp(2.2rem, 6vw, 3.5rem);
    line-height: 0.94;
  }

  .footer-copy p:last-child {
    max-width: 58ch;
    color: var(--color-muted);
  }

  .footer-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    align-items: center;
  }

  @media (min-width: 880px) {
    .footer-shell {
      grid-template-columns: minmax(0, 1.3fr) auto;
      align-items: center;
    }
  }
</style>
