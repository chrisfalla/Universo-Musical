---
import { createWhatsAppLink } from '../lib/whatsapp';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

const navigation = [
  { href: '/', label: 'Inicio' },
  { href: '/instrumentos', label: 'Instrumentos' },
  { href: '/accesorios', label: 'Accesorios' }
];

const whatsAppLink = createWhatsAppLink(
  'Hola, quiero recibir asesoria sobre el catalogo de Universo Musical.'
);
---

<header class="site-header">
  <div class="container header-shell">
    <a class="brand" href="/" aria-label="Ir al inicio de Universo Musical">
      <span class="brand-badge" aria-hidden="true">UM</span>
      <span class="brand-copy">
        <strong class="display-font">Universo Musical</strong>
        <span>Catalogo real para compra por WhatsApp</span>
      </span>
    </a>

    <nav class="main-nav" aria-label="Navegacion principal">
      <ul role="list">
        {
          navigation.map((item) => (
            <li>
              <a class:list={['nav-link', currentPath === item.href && 'is-active']} href={item.href}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <a class="button button-primary header-cta" href={whatsAppLink} target="_blank" rel="noreferrer">
      WhatsApp
    </a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 30;
    backdrop-filter: blur(16px);
    background: linear-gradient(180deg, rgba(11, 15, 22, 0.94), rgba(11, 15, 22, 0.78));
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .header-shell {
    min-height: 5.3rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    min-width: 0;
  }

  .brand-badge {
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 0.9rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 1.4rem;
    letter-spacing: 0.08em;
    color: var(--color-base);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.2), transparent),
      linear-gradient(135deg, var(--color-accent), var(--color-secondary));
    box-shadow: 0 0.95rem 2rem rgba(240, 173, 78, 0.28);
  }

  .brand-copy {
    display: grid;
    gap: 0.15rem;
    min-width: 0;
  }

  .brand-copy strong {
    font-size: 1.5rem;
    line-height: 0.95;
  }

  .brand-copy span {
    color: var(--color-muted);
    font-size: 0.8rem;
    letter-spacing: 0.02em;
  }

  .main-nav {
    display: none;
  }

  .main-nav ul {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.7rem;
    padding: 0 1rem;
    border-radius: 999px;
    color: var(--color-muted);
    font-size: 0.94rem;
    font-weight: 600;
    transition:
      color var(--transition-fast),
      background-color var(--transition-fast),
      border-color var(--transition-fast);
  }

  .nav-link:hover,
  .nav-link.is-active {
    color: var(--color-foreground);
    background: rgba(255, 255, 255, 0.08);
  }

  .header-cta {
    display: none;
  }

  @media (min-width: 760px) {
    .main-nav,
    .header-cta {
      display: flex;
    }
  }

  @media (max-width: 759px) {
    .brand-copy span {
      display: none;
    }
  }
</style>
