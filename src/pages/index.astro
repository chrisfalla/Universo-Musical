---
import Layout from '../layouts/Layout.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import WhatsAppFab from '../components/WhatsAppFab.astro';
import { getCatalogSnapshot } from '../lib/catalog';
import { WHATSAPP_DISPLAY, createWhatsAppLink } from '../lib/whatsapp';

const { instrumentos, accesorios } = getCatalogSnapshot();

const heroLink = createWhatsAppLink(
  'Hola, quiero asesoria para elegir un instrumento o accesorio en Universo Musical.'
);

const instrumentPreviewFamilies = instrumentos.familySummaries
  .filter((family) => family.family !== 'Otros')
  .slice(0, 4);
const accessoryPreviewFamilies = accesorios.familySummaries
  .filter((family) => family.family !== 'Otros')
  .slice(0, 4);

const benefits = [
  {
    title: 'Inventario real y ordenado',
    body: 'La web ahora prioriza lo que si existe en bodega y lo presenta por familias para que encontrar sea mas facil.'
  },
  {
    title: 'Compra conversacional',
    body: 'Cada vista lleva a WhatsApp con el producto exacto, asi la cotizacion arranca con contexto y sin vueltas.'
  },
  {
    title: 'Disponibilidad visible',
    body: 'Mostramos precios y estados de inventario cuando el dato es valido, sin saturar la home con cientos de referencias.'
  }
];

const purchaseFlow = [
  'Explora instrumentos o accesorios por familia.',
  'Filtra por nombre, revisa precio y disponibilidad.',
  'Confirma por WhatsApp con el articulo exacto ya precargado.'
];
---

<Layout
  title="Universo Musical | Catalogo musical con compra por WhatsApp"
  description="Explora instrumentos y accesorios de Universo Musical con inventario organizado, precios visibles y contacto directo por WhatsApp."
>
  <SiteHeader currentPath="/" />

  <main>
    <section class="section hero-home">
      <div class="container hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">Catalogo musical vivo</p>
          <h1 class="display-font">Instrumentos y accesorios listos para vender mejor, sin saturar tu inicio.</h1>
          <p>
            Reordenamos la experiencia de Universo Musical para que la primera impresion sea clara, comercial
            y rapida: una home que presenta la marca y dos vistas pensadas para explorar el inventario real
            con criterio.
          </p>

          <div class="hero-actions">
            <a class="button button-primary" href={heroLink} target="_blank" rel="noreferrer">
              Escribir a WhatsApp
            </a>
            <a class="button button-secondary" href="/instrumentos">Ver instrumentos</a>
          </div>

          <div class="hero-metrics">
            <article>
              <strong>{instrumentos.totalItems + accesorios.totalItems}</strong>
              <span>referencias limpias en el catalogo</span>
            </article>
            <article>
              <strong>{instrumentos.availableItems + accesorios.availableItems}</strong>
              <span>con disponibilidad visible</span>
            </article>
            <article>
              <strong>{WHATSAPP_DISPLAY}</strong>
              <span>canal directo para cerrar la venta</span>
            </article>
          </div>
        </div>

        <div class="hero-panels">
          <article class="overview-card panel instruments-card">
            <p class="eyebrow">Instrumentos</p>
            <h2 class="display-font">{instrumentos.totalItems} referencias</h2>
            <p>Catalogo enfocado en cuerdas, teclados, percusion, vientos y audio con filtros para navegar rapido.</p>

            <div class="family-pills">
              {instrumentPreviewFamilies.map((family) => <span>{family.family}</span>)}
            </div>

            <a href="/instrumentos">Explorar instrumentos</a>
          </article>

          <article class="overview-card panel accessories-card">
            <p class="eyebrow">Accesorios</p>
            <h2 class="display-font">{accesorios.totalItems} referencias</h2>
            <p>Acceso directo a encordados, estuches, cables y repuestos sin hacer interminable la pagina principal.</p>

            <div class="family-pills">
              {accessoryPreviewFamilies.map((family) => <span>{family.family}</span>)}
            </div>

            <a href="/accesorios">Explorar accesorios</a>
          </article>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container stack">
        <div class="section-head">
          <p class="eyebrow">Arquitectura comercial</p>
          <h2 class="display-font">Una home para orientar, dos catalogos para convertir.</h2>
          <p class="section-copy">
            La pagina ya no intenta meter todo en un solo scroll. Ahora separa el recorrido en puntos de
            decision claros para que el usuario entre, entienda y escriba mas rapido.
          </p>
        </div>

        <div class="category-grid">
          <article class="category-panel panel">
            <div class="category-copy">
              <p class="eyebrow">Vista 01</p>
              <h3 class="display-font">Instrumentos</h3>
              <p>
                {instrumentos.availableItems} productos con disponibilidad visible y {instrumentos.pricedItems}{' '}
                con precio publicado, organizados por familia y ordenados alfabeticamente.
              </p>
            </div>
            <a class="button button-primary" href="/instrumentos">Ir al catalogo de instrumentos</a>
          </article>

          <article class="category-panel panel">
            <div class="category-copy">
              <p class="eyebrow">Vista 02</p>
              <h3 class="display-font">Accesorios</h3>
              <p>
                {accesorios.availableItems} referencias disponibles y una navegacion pensada para encontrar
                rapido cuerdas, estuches, cables y otros complementos.
              </p>
            </div>
            <a class="button button-primary" href="/accesorios">Ir al catalogo de accesorios</a>
          </article>
        </div>
      </div>
    </section>

    <section class="section benefits-section">
      <div class="container stack">
        <div class="section-head">
          <p class="eyebrow">Mejoras UX</p>
          <h2 class="display-font">Menos relleno, mas orientacion y mejores caminos de compra.</h2>
        </div>

        <div class="benefits-grid">
          {
            benefits.map((benefit, index) => (
              <article class="benefit-card panel">
                <span class="benefit-index">{String(index + 1).padStart(2, '0')}</span>
                <h3>{benefit.title}</h3>
                <p>{benefit.body}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section process-section">
      <div class="container process-grid">
        <div class="process-copy">
          <p class="eyebrow">Como comprar</p>
          <h2 class="display-font">El nuevo flujo elimina friccion desde la primera visita.</h2>
          <p>
            La experiencia fue replanteada para que el usuario no se pierda. Primero ubica la categoria,
            luego filtra el producto y finalmente llega a WhatsApp con el mensaje listo.
          </p>
        </div>

        <div class="process-list">
          {
            purchaseFlow.map((step, index) => (
              <article class="process-item panel">
                <strong>{index + 1}</strong>
                <p>{step}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section contact-strip">
      <div class="container contact-card panel">
        <div class="stack">
          <p class="eyebrow">Canal confirmado</p>
          <h2 class="display-font">Toda la conversion vive en WhatsApp.</h2>
          <p>
            En esta primera entrega dejamos afuera correo, direccion y formulario para no publicar datos
            ficticios. El canal real y prioritario del negocio queda centralizado en {WHATSAPP_DISPLAY}.
          </p>
        </div>
        <a class="button button-primary" href={heroLink} target="_blank" rel="noreferrer">
          Abrir WhatsApp
        </a>
      </div>
    </section>
  </main>

  <SiteFooter />
  <WhatsAppFab />
</Layout>

<style>
  .hero-home {
    padding-top: clamp(3rem, 8vw, 5.2rem);
  }

  .hero-grid {
    display: grid;
    gap: 1.25rem;
    align-items: start;
  }

  .hero-copy {
    display: grid;
    gap: 1.1rem;
  }

  .hero-copy h1 {
    font-size: clamp(3.2rem, 10vw, 7rem);
    max-width: 10.6ch;
  }

  .hero-copy p:last-of-type {
    max-width: 60ch;
    color: var(--color-muted);
    font-size: 1.02rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .hero-metrics {
    display: grid;
    gap: 0.8rem;
    grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
  }

  .hero-metrics article {
    padding: 1rem;
    border-radius: 1.1rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.04);
  }

  .hero-metrics strong {
    display: block;
    margin-bottom: 0.35rem;
    font-size: 1.2rem;
    color: var(--color-accent-soft);
  }

  .hero-metrics span,
  .section-copy {
    color: var(--color-muted);
  }

  .hero-panels {
    display: grid;
    gap: 1rem;
  }

  .overview-card {
    display: grid;
    gap: 0.9rem;
    position: relative;
    overflow: hidden;
  }

  .overview-card::after {
    content: '';
    position: absolute;
    inset: auto -10% -20% auto;
    width: 14rem;
    height: 14rem;
    border-radius: 50%;
    filter: blur(1rem);
    opacity: 0.45;
  }

  .instruments-card::after {
    background: rgba(240, 173, 78, 0.28);
  }

  .accessories-card::after {
    background: rgba(35, 92, 112, 0.32);
  }

  .overview-card h2 {
    font-size: clamp(2.4rem, 7vw, 4rem);
  }

  .overview-card p:last-of-type {
    color: var(--color-muted);
    max-width: 32ch;
  }

  .overview-card a {
    color: var(--color-accent-soft);
    font-weight: 700;
  }

  .family-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .family-pills span {
    min-height: 2rem;
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.7rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.07);
    color: var(--color-foreground);
    font-size: 0.8rem;
    font-weight: 600;
  }

  .category-grid,
  .benefits-grid {
    display: grid;
    gap: 1rem;
  }

  .category-panel,
  .benefit-card {
    display: grid;
    gap: 1rem;
  }

  .category-copy,
  .process-copy {
    display: grid;
    gap: 0.8rem;
  }

  .category-panel h3,
  .benefit-card h3 {
    font-size: 1.7rem;
  }

  .category-panel p,
  .benefit-card p,
  .process-copy p,
  .contact-card p {
    color: var(--color-muted);
  }

  .benefit-index {
    width: 2.4rem;
    height: 2.4rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    color: var(--color-base);
    background: linear-gradient(135deg, var(--color-accent), var(--color-secondary));
    font-weight: 800;
  }

  .process-grid {
    display: grid;
    gap: 1rem;
    align-items: start;
  }

  .process-copy h2,
  .contact-card h2,
  .section-head h2 {
    font-size: clamp(2.6rem, 7vw, 4.4rem);
  }

  .process-list {
    display: grid;
    gap: 0.9rem;
  }

  .process-item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.85rem;
    align-items: start;
  }

  .process-item strong {
    width: 2.4rem;
    height: 2.4rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    color: var(--color-base);
    background: var(--color-accent);
  }

  .contact-card {
    display: grid;
    gap: 1rem;
    align-items: center;
  }

  @media (min-width: 900px) {
    .hero-grid,
    .process-grid,
    .contact-card {
      grid-template-columns: minmax(0, 1.1fr) minmax(18rem, 0.9fr);
    }

    .category-grid,
    .benefits-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
